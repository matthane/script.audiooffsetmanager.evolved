<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<!-- Hand-written (the generator died with the offset matrix in E3): offsets
     live in the sparse JSON store, never here (P4), so this file holds only
     behavior settings. Every id must be read by Python and vice versa - the
     two-way contract test enforces it. -->
<settings version="1">
    <section id="script.audiooffsetmanagerevolved">
        <!-- Offset learning: the product. -->
        <category id="learning" label="32105" help="32106">
            <group id="1" label="32107">
                <setting id="remember_adjustments" type="boolean" label="32108" help="32109">
                    <level>0</level>
                    <default>true</default>
                    <control type="toggle"/>
                </setting>
                <setting id="per_fps_offsets" type="boolean" label="32110" help="32111">
                    <level>0</level>
                    <default>false</default>
                    <control type="toggle"/>
                </setting>
                <setting id="pause_offsets" type="boolean" label="32112" help="32113">
                    <level>0</level>
                    <default>false</default>
                    <control type="toggle"/>
                </setting>
            </group>
            <group id="2" label="32114">
                <setting id="manage_offsets" type="action" label="32115" help="32116">
                    <level>0</level>
                    <data>RunScript(script.audiooffsetmanagerevolved,manage_offsets)</data>
                    <!-- close: the write-ordering doctrine survives for
                         behavior settings - never act while the dialog's
                         save-on-close is pending. -->
                    <control type="button" format="action">
                        <close>true</close>
                    </control>
                </setting>
            </group>
        </category>

        <!-- Playback behavior: seek-backs and notifications. -->
        <category id="playback" label="32016" help="32017">
            <group id="3" label="32018">
                <!-- Seek back upon opening video player -->
                <setting id="enable_seek_back_resume" type="boolean" label="32034" help="32035">
                    <level>0</level>
                    <default>false</default>
                    <control type="toggle"/>
                </setting>
                <setting id="seek_back_resume_seconds" parent="enable_seek_back_resume" type="integer" label="32021" help="32037">
                    <level>0</level>
                    <dependencies>
                        <dependency type="visible" setting="enable_seek_back_resume">true</dependency>
                    </dependencies>
                    <default>4</default>
                    <constraints>
                        <minimum>1</minimum>
                        <step>1</step>
                        <maximum>10</maximum>
                    </constraints>
                    <control type="slider" format="integer">
                        <popup>false</popup>
                    </control>
                </setting>

                <!-- Seek back on unpausing video -->
                <setting id="enable_seek_back_unpause" type="boolean" label="32038" help="32039">
                    <level>0</level>
                    <default>false</default>
                    <control type="toggle"/>
                </setting>
                <setting id="seek_back_unpause_seconds" parent="enable_seek_back_unpause" type="integer" label="32021" help="32041">
                    <level>0</level>
                    <dependencies>
                        <dependency type="visible" setting="enable_seek_back_unpause">true</dependency>
                    </dependencies>
                    <default>4</default>
                    <constraints>
                        <minimum>1</minimum>
                        <step>1</step>
                        <maximum>10</maximum>
                    </constraints>
                    <control type="slider" format="integer">
                        <popup>false</popup>
                    </control>
                </setting>

                <!-- Seek back on audio format change (the scheduler's
                     'adjust' reason: a change-announcing stabilization) -->
                <setting id="enable_seek_back_adjust" type="boolean" label="32019" help="32020">
                    <level>0</level>
                    <default>false</default>
                    <control type="toggle"/>
                </setting>
                <setting id="seek_back_adjust_seconds" parent="enable_seek_back_adjust" type="integer" label="32021" help="32022">
                    <level>0</level>
                    <dependencies>
                        <dependency type="visible" setting="enable_seek_back_adjust">true</dependency>
                    </dependencies>
                    <default>4</default>
                    <constraints>
                        <minimum>1</minimum>
                        <step>1</step>
                        <maximum>10</maximum>
                    </constraints>
                    <control type="slider" format="integer">
                        <popup>false</popup>
                    </control>
                </setting>

                <!-- Seek back on manual offset change (the scheduler's
                     'change' reason: the watcher stored an adjustment) -->
                <setting id="enable_seek_back_change" type="boolean" label="32048" help="32049">
                    <level>0</level>
                    <default>false</default>
                    <control type="toggle"/>
                </setting>
                <setting id="seek_back_change_seconds" parent="enable_seek_back_change" type="integer" label="32021" help="32050">
                    <level>0</level>
                    <dependencies>
                        <dependency type="visible" setting="enable_seek_back_change">true</dependency>
                    </dependencies>
                    <default>4</default>
                    <constraints>
                        <minimum>1</minimum>
                        <step>1</step>
                        <maximum>10</maximum>
                    </constraints>
                    <control type="slider" format="integer">
                        <popup>false</popup>
                    </control>
                </setting>
            </group>

            <group id="4" label="32081">
                <!-- D10: per-kind toast gates, both default ON (the toasts
                     are the learn loop's teaching surface). -->
                <setting id="notify_apply" type="boolean" label="32117" help="32118">
                    <level>0</level>
                    <default>true</default>
                    <control type="toggle"/>
                </setting>
                <setting id="notify_learn" type="boolean" label="32119" help="32120">
                    <level>0</level>
                    <default>true</default>
                    <control type="toggle"/>
                </setting>
                <setting id="notification_seconds" type="integer" label="32090" help="32091">
                    <level>0</level>
                    <dependencies>
                        <dependency type="visible">
                            <or>
                                <condition setting="notify_apply">true</condition>
                                <condition setting="notify_learn">true</condition>
                            </or>
                        </dependency>
                    </dependencies>
                    <default>5</default>
                    <constraints>
                        <minimum>1</minimum>
                        <step>1</step>
                        <maximum>10</maximum>
                    </constraints>
                    <control type="slider" format="integer">
                        <popup>false</popup>
                    </control>
                </setting>
            </group>
        </category>

        <!-- Advanced -->
        <category id="advanced" label="32100" help="32101">
            <group id="5" label="32102">
                <setting id="enable_debug_logging" type="boolean" label="32103" help="32104">
                    <level>0</level>
                    <default>false</default>
                    <control type="toggle"/>
                </setting>
                <!-- Internal once-flag (level 4, never rendered): set after
                     the classic-AOM coexistence warning has shown once.
                     Behavior state, not offset data. -->
                <setting id="coexistence_warned" type="boolean" label="">
                    <level>4</level>
                    <default>false</default>
                    <control type="toggle"/>
                </setting>
            </group>
        </category>
    </section>
</settings>
